# Convex
CONVEX_DEPLOYMENT=             # e.g. dev:your-project-123
VITE_CONVEX_URL=               # e.g. https://your-project-123.convex.cloud

# Stripe (set in Convex dashboard → Environment Variables)
STRIPE_WEBHOOK_ACCOUNT_SECRET= # whsec_... from Stripe dashboard (account/platform webhook)
STRIPE_WEBHOOK_CONNECT_SECRET= # whsec_... from Stripe dashboard (connect webhook)
STRIPE_SECRET_KEY=             # sk_test_... or sk_live_...
STRIPE_PRICE_SCRUB_SOLO=       # Stripe price ID for Solo ($34.99/mo)
STRIPE_PRICE_SCRUB_TEAM=       # Stripe price ID for Team ($64.99/mo)
STRIPE_PRICE_SCRUB_PRO=        # Stripe price ID for Pro ($149.99/mo)
STRIPE_PRICE_SCRUB_PRO_LEGACY= # Legacy Pro price ID (grandfathered users)

# Security
TOKEN_PEPPER=                  # random string used to pepper token hashes
